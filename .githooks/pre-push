#!/bin/sh
set -eu

remote_name="${1:-origin}"
remote_url="${2:-}"
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue

  if [ "$remote_ref" = "refs/heads/main" ] || [ "$local_ref" = "refs/heads/main" ]; then
    if [ "${AGENTHOOK_ALLOW_DIRECT_MAIN:-}" != "1" ]; then
      cat >&2 <<EOF
Direct pushes to AgentHook main are blocked.

Create a branch, commit with DCO sign-off, and open a pull request.
Override only for steward emergency fixes:
  AGENTHOOK_ALLOW_DIRECT_MAIN=1 AGENTHOOK_STEWARD_OK_TO_PUSH=1 git push $remote_name main
EOF
      blocked=1
      continue
    fi
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for commit in $(git rev-list "$range"); do
    if ! git log --format=%B -n 1 "$commit" | grep -qE '^Signed-off-by: .+ <.+@.+>$'; then
      echo "Commit $commit is missing a Signed-off-by line." >&2
      echo "Fix with: git rebase --signoff main" >&2
      blocked=1
    fi
  done
done

if [ "$blocked" -ne 0 ]; then
  exit 1
fi

if [ "${AGENTHOOK_ALLOW_DIRECT_MAIN:-}" = "1" ] && [ "${AGENTHOOK_STEWARD_OK_TO_PUSH:-}" != "1" ]; then
  echo "Emergency direct-main override also requires AGENTHOOK_STEWARD_OK_TO_PUSH=1." >&2
  exit 1
fi
